# Copy this to .env for local dev — never commit .env

# ── UiPath auth (preferred: client_credentials, no manual refresh) ─────────
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
# Fallback static token if the two above aren't set (expires ~1hr):
# UIPATH_ACCESS_TOKEN=

# Tenant base URL
UIPATH_BASE_URL=https://staging.uipath.com/hackathon26_332/DefaultTenant

# Shared/ReimbursementFullSolution
UIPATH_FOLDER_ID=3152226
# "Receipt" bucket, created in this folder for MirCaseClone/IntakeBot
UIPATH_BUCKET_ID=232381
# MirCaseClone release key
UIPATH_CASE_RELEASE_KEY=BE62E793-6695-436B-8D22-CAF6A2ED6416
# SubmissionConfirmationAgent release key
UIPATH_CONFIRMATION_RELEASE_KEY=ff4b2d54-d0f9-43b7-a21b-7ac1d90afe1a

# ── Resend — belt-and-suspenders finance/manager notification ──────────────
# Free tier without a verified sending domain only delivers to RESEND_NOTIFY_TO
# (or whatever address owns the Resend account) — real submitter/manager
# addresses are still reliably reached via the Gmail-based
# SubmissionConfirmationAgent above, not this.
RESEND_API_KEY=
RESEND_NOTIFY_TO=akashgomez28@gmail.com

# ── Stripe — NOT consumed by this app directly. The payout happens inside
# MirCaseClone's own StripePayoutWorkflow stage, which reads its
# stripe_secret_key/stripe_publishable_key from the Case's own binding
# config (set once in Studio Web), not from this service's env. Only set
# these here if you extend this app to call StripePayoutWorkflow directly.
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# ── /admin panel + /dashboard live-ops — required, no default (every
# /admin and /api/admin/* route fails closed with a 500 if either is unset) ─
ADMIN_USER=
ADMIN_PASSWORD=
