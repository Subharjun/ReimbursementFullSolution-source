# Copy this to .env for local dev — never commit .env

# ── UiPath auth (preferred: client_credentials, no manual refresh) ─────────
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# Fallback static token if the two above aren't set (expires ~1hr):
# UIPATH_ACCESS_TOKEN=

# Tenant base URL
UIPATH_BASE_URL=https://staging.uipath.com/hackathon26_332/DefaultTenant

# Shared/ReimbursementFullSolution
UIPATH_ADMIN_FOLDER_ID=3152226
UIPATH_FOLDER_KEY=a1dc9c4b-4ba4-4ac1-837d-9c6b093457a3
UIPATH_ORG_UNIT_ID=3152226
UIPATH_ORCH_FOLDER_ID=3152226

# SubmissionConfirmationAgent release key (for the /api/admin/test-confirmation demo route)
UIPATH_CONFIRMATION_RELEASE_KEY=ff4b2d54-d0f9-43b7-a21b-7ac1d90afe1a

# ── Admin panel HTTP Basic auth — required, no default (every /admin route
# fails closed with a 500 if either is unset) ───────────────────────────────
ADMIN_USER=
ADMIN_PASSWORD=

# ── Optional: real Stripe payout on AUTO_APPROVE/PROCEED verdicts ──────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
